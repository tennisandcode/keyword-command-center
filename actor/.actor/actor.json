{
  "actorSpecification": 1,
  "name": "h10-keyword-finder",
  "title": "H10 Keyword Finder (Cerebro → Sheets/Postgres)",
  "version": "0.1",
  "dockerfile": "../Dockerfile",
  "input": {
    "title": "Run input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
      "asins": {
        "title": "ASINs to process",
        "type": "array",
        "editor": "stringList",
        "prefill": ["B0DDQL7PVM"],
        "description": "One or more ASINs. If empty, the actor fetches active products from the portal API."
      },
      "minSearchVolume": { "title": "Min search volume", "type": "integer", "default": 400 },
      "rankMin": { "title": "Organic rank min", "type": "integer", "default": 20 },
      "rankMax": { "title": "Organic rank max", "type": "integer", "default": 80 },
      "highOppVolume": { "title": "High-opportunity volume threshold", "type": "integer", "default": 800 },
      "highOppRankMax": { "title": "High-opportunity rank max", "type": "integer", "default": 50 },
      "maxKeywords": { "title": "Max keywords per ASIN", "type": "integer", "default": 150 },
      "maxCompetitorLookups": { "title": "Max competitor lookups per ASIN", "type": "integer", "default": 3 },
      "deepCompetitors": { "title": "Deep competitor X-ray (visit product pages)", "type": "boolean", "default": true },
      "weeklyPpcBudget": { "title": "Weekly PPC budget ($) for plan allocation", "type": "integer", "default": 500 },
      "productPrice": { "title": "Your product price (cost-to-rank math)", "type": "integer", "default": 149 },
      "loginWaitMinutes": {
        "title": "Login handoff wait (minutes)",
        "type": "integer",
        "default": 10,
        "description": "If the saved Helium 10 session is dead, the actor pauses on the login page this long so you can sign in via Live View."
      },
      "brandBlocklist": {
        "title": "Branded terms to exclude",
        "type": "array",
        "editor": "stringList",
        "prefill": ["nobl", "cotopaxi", "northface", "north face", "crocs", "thule", "tomtoc", "alming", "ryanair", "jansport", "swissgear", "matein", "lovevook", "taygeer", "bange", "vacbird"]
      }
    }
  }
}
